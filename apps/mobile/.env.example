# Work around Expo CLI response-cache bug ("Body has already been read") on Windows.
EXPO_NO_CACHE=1

# Skip online dependency validation (avoids "fetch failed" when Expo API is unreachable).
EXPO_NO_DEPENDENCY_VALIDATION=1

# Optional override for local development.
# On a physical phone, point this to your computer's LAN IP.
# Example: EXPO_PUBLIC_BACKEND_URL=http://192.168.0.42:5000
EXPO_PUBLIC_BACKEND_URL=

# Optional override for the Spring Boot notification service.
# Example: EXPO_PUBLIC_NOTIFICATION_SERVICE_URL=http://192.168.0.42:8080
EXPO_PUBLIC_NOTIFICATION_SERVICE_URL=
