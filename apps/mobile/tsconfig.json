{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"baseUrl": ".",
		"jsx": "react-jsx",
		"paths": {
			"~/*": [
				"*"
			],
			"@firebase/auth": ["./node_modules/@firebase/auth/dist/index.rn.d.ts"]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		"nativewind-env.d.ts"
	],
	"exclude": [
		"android",
		"vendor-node_modules",
		"node_modules"
	]
}
